generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id             String      @id @default(cuid())
  youtubeVideoId String      @unique
  slug           String      @unique
  title          String
  description    String?
  summary        String?
  thumbnailUrl   String?
  duration       String?
  viewCount      Int?
  likeCount      Int?
  commentCount   Int?
  publishedAt    DateTime?
  language       String?
  status         VideoStatus @default(DRAFT)
  isFeatured     Boolean     @default(false)

  aiShortSummary       String?
  aiLongSummary        String?
  aiKeyPoints          String?
  aiTags               String?
  aiSeoTitle           String?
  aiSeoDescription     String?
  aiLanguage           String?
  aiCategorySuggestion String?
  aiConfidence         Float?
  aiNeedsHumanReview   Boolean           @default(true)
  aiGeneratedAt        DateTime?
  aiStatus             AiSummaryStatus   @default(NOT_GENERATED)
  aiError              String?
  aiMetadata           VideoAiMetadata[]

  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags VideoTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([channelId])
}

model Channel {
  id                String        @id @default(cuid())
  youtubeChannelId  String        @unique
  slug              String        @unique
  title             String
  description       String?
  thumbnailUrl      String?
  subscriberCount   Int?
  videoCount        Int?
  status            ChannelStatus @default(ACTIVE)
  uploadsPlaylistId String?
  autoImportEnabled Boolean       @default(false)
  defaultLanguage   String?
  defaultStatus     VideoStatus   @default(DRAFT)
  lastImportedAt    DateTime?

  defaultCategoryId String?
  defaultCategory   Category? @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)

  videos Video[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  videos   Video[]
  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id     String     @id @default(cuid())
  slug   String     @unique
  name   String
  videos VideoTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model VideoTag {
  videoId String
  tagId   String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([videoId, tagId])
  @@index([tagId])
}

model VideoAiMetadata {
  id                 String               @id @default(cuid())
  videoId            String
  language           String
  slug               String?
  shortSummary       String?
  longSummary        String?
  keyPoints          String?
  tags               String?
  seoTitle           String?
  seoDescription     String?
  detectedLanguage   String?
  categorySuggestion String?
  confidence         Float?
  needsHumanReview   Boolean              @default(true)
  generatedAt        DateTime?
  status             AiSummaryStatus      @default(NOT_GENERATED)
  error              String?
  localizedStatus    LocalizedVideoStatus @default(DRAFT)
  publishedAt        DateTime?

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([videoId, language])
  @@unique([language, slug])
  @@index([language])
  @@index([language, localizedStatus])
}

model VideoSuggestion {
  id         String           @id @default(cuid())
  youtubeUrl String
  category   String?
  language   String?
  message    String?
  email      String?
  status     SuggestionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  language  String?
  createdAt DateTime @default(now())
}

enum VideoStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AiSummaryStatus {
  NOT_GENERATED
  GENERATING
  GENERATED
  FAILED
}

enum LocalizedVideoStatus {
  DRAFT
  PUBLISHED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChannelStatus {
  ACTIVE
  HIDDEN
}
